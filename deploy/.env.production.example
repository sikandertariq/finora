# Copy to /srv/finora/.env.production on EC2. This file is private and is
# generated from SSM Parameter Store during deployment; never commit it.
FINORA_BACKEND_IMAGE=ghcr.io/YOUR_GITHUB_OWNER/finora-backend:main
DJANGO_SECRET_KEY=generate-a-long-random-value
DJANGO_ALLOWED_HOSTS=YOUR_ELASTIC_IP
DJANGO_CSRF_TRUSTED_ORIGINS=https://YOUR_ELASTIC_IP
CORS_ALLOWED_ORIGINS=
DATABASE_URL=postgres://finora:replace-with-url-safe-password@postgres:5432/finora
POSTGRES_USER=finora
POSTGRES_PASSWORD=replace-with-url-safe-password
POSTGRES_DB=finora
REDIS_URL=redis://redis:6379/0
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
DEMO_USER_PASSWORD=demo-password
RECEIPT_UPLOAD_THROTTLE=10/hour
MAX_RECEIPT_UPLOAD_BYTES=5242880
